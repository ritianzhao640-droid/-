# 币安长征 API 服务器配置

# 服务端口
PORT=3000

# BSC RPC 节点（优先使用私有节点，如果没有就留空用默认公共节点）
# 🛡️ 建议配置多个备用节点，用逗号分隔
BSC_RPC_URL=https://bsc-dataseed.binance.org/,https://bsc-dataseed1.defibit.io/,https://bsc-dataseed2.ninicoin.io/

# 缓存刷新间隔（秒），默认 300 = 5分钟
# 🛡️ 建议生产环境设置为 60-180 秒，平衡实时性和性能
CACHE_REFRESH_INTERVAL=180

# 奖励数据更新间隔（分钟），默认 30
REWARDS_UPDATE_INTERVAL=30

# CORS 允许的来源（生产环境填你的域名）
CORS_ORIGIN=https://bacz.ltd

# 🛡️ 性能优化配置
# 请求超时时间（毫秒）
REQUEST_TIMEOUT=15000

# 链上请求重试次数
CHAIN_RETRY_COUNT=3

# 是否启用压缩
ENABLE_COMPRESSION=true

# 静态文件缓存时间（秒）
STATIC_MAX_AGE=86400
